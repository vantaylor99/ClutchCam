# Compose profiles.
# local-linux starts the integrated SRS, buffer-worker, and orchestrator path.
# Use local-ai for the bundled Ollama service, or omit it when GEMMA_API_URL
# points at a host or remote GPU endpoint. Do not include transcription-worker
# in the integrated profile set; run it explicitly for JSONL diagnostics.
# Add local-transcription only when you want Compose to start the optional
# Faster-Whisper-compatible server.
COMPOSE_PROFILES=local-linux,local-ai

# OBS WebSocket settings.
# In OBS: Tools > WebSocket Server Settings.
# OBS_HOST may be 127.0.0.1 for direct local Python, host.docker.internal for
# Docker Desktop reaching host OBS, or a LAN host/IP when OBS is elsewhere.
# OBS_PORT must be 1-65535. Keep OBS_PASSWORD in an uncommitted local secret
# file; leave it empty only when OBS WebSocket authentication is disabled.
OBS_HOST=host.docker.internal
OBS_PORT=4455
OBS_PASSWORD=change-me
DRY_RUN_OBS=false

# Local SRS media-server settings.
# Keep SRS_BIND_ADDR=127.0.0.1 for host-local testing. Use 0.0.0.0 only when
# the LAN firewall boundary is intentional.
SRS_IMAGE=ossrs/srs:6
SRS_BIND_ADDR=127.0.0.1
SRS_RTMP_PORT=1935
SRS_HTTP_API_PORT=1985
SRS_HTTP_STREAM_PORT=8080
SRS_SRT_PORT=10080

# Runtime service boundaries.
# Compose workers default to the local media-server DNS name. Override this
# when media ingest is supplied by another host. INGEST_API_URL and per-stream
# input overrides must be absolute rtmp, rtmps, srt, http, https, or file URLs.
INGEST_API_URL=rtmp://media-server:1935/live

# GEMMA_API_URL and TRANSCRIPTION_API_URL are HTTP(S) endpoint contracts. They
# may use Compose service DNS, host.docker.internal, LAN hosts, or remote/cloud
# endpoints. Secret-ish env names such as *_API_KEY, *_TOKEN, *_PASSWORD, and
# *_SECRET are redacted from structured health/config details.
AI_PROVIDER=ollama
# AI_PROVIDER=openai-compatible
GEMMA_API_URL=http://ollama:11434
# GEMMA_API_URL=http://host.docker.internal:11434
# For OpenAI-compatible servers such as vLLM, point at the host or a full
# /v1/chat/completions path.
# GEMMA_API_URL=https://gemma-gpu.example.internal
GEMMA_API_KEY=
TRANSCRIPTION_API_URL=http://host.docker.internal:8000
# TRANSCRIPTION_API_URL=http://faster-whisper:8000
# TRANSCRIPTION_API_URL=https://stt-gpu.example.internal
# Default posts JSON audio references to <TRANSCRIPTION_API_URL>/transcribe.
TRANSCRIPTION_REQUEST_MODE=json
# For stock OpenAI-compatible Faster-Whisper servers, opt into multipart upload:
# TRANSCRIPTION_REQUEST_MODE=openai-compatible
# TRANSCRIPTION_ENDPOINT_PATH=/v1/audio/transcriptions
# chunked keeps fixed audio chunk discovery. vad-utterance assembles local
# speech-pause windows before sending audio to the transcription provider.
TRANSCRIPTION_SOURCE_MODE=chunked
TRANSCRIPTION_MODEL=Systran/faster-whisper-small
TRANSCRIPTION_LANGUAGE=
TRANSCRIPTION_RESPONSE_FORMAT=json
TRANSCRIPTION_REQUEST_TIMEOUT_SECONDS=30
TRANSCRIPTION_REQUEST_OVERLAP_SECONDS=0
# Local voice activity detection settings used only by
# TRANSCRIPTION_SOURCE_MODE=vad-utterance. VAD requires mono pcm_s16le WAV
# extraction so Python can inspect the audio before provider requests.
TRANSCRIPTION_VAD_FRAME_MS=30
TRANSCRIPTION_VAD_ENERGY_THRESHOLD=0.015
TRANSCRIPTION_VAD_MIN_SPEECH_SECONDS=0.18
TRANSCRIPTION_VAD_MIN_SILENCE_SECONDS=0.45
TRANSCRIPTION_VAD_LEADING_PADDING_SECONDS=0.18
TRANSCRIPTION_VAD_TRAILING_PADDING_SECONDS=0.24
TRANSCRIPTION_VAD_MAX_UTTERANCE_SECONDS=12
# Set true to let the orchestrator own live audio extraction and transcript
# events. Keep false when using terminal transcript input only.
LIVE_TRANSCRIPTION_ENABLED=false
LIVE_TRANSCRIPTION_QUEUE_SIZE=16
# Opt in only for evaluation/debugging; accepted runtime transcript text can
# include private player speech.
TRANSCRIPT_LOG_TEXT_ENABLED=false
TRANSCRIPT_LOG_TEXT_MAX_CHARACTERS=160

# Local AI model storage.
OLLAMA_BIND_ADDR=127.0.0.1
OLLAMA_PORT=11434
# The local readiness checkpoint defaults to the current text-only Gemma loop.
# Future multimodal work can select a text/image-capable Gemma model tag, but
# changing the model alone does not enable vision/keyframe analysis.
GEMMA_MODEL=gemma3:4b
OLLAMA_MODEL=gemma3:4b
OLLAMA_BASE_URL=http://ollama:11434

# Optional local Faster-Whisper-compatible transcription server.
# The default image is CPU-safe. For NVIDIA hosts, set the CUDA image and
# FASTER_WHISPER_DEVICE=cuda, then expose GPUs with a local Compose override
# if your Docker daemon does not make them available automatically.
FASTER_WHISPER_IMAGE=fedirz/faster-whisper-server:latest-cpu
# FASTER_WHISPER_IMAGE=fedirz/faster-whisper-server:latest-cuda
FASTER_WHISPER_BIND_ADDR=127.0.0.1
FASTER_WHISPER_PORT=8000
FASTER_WHISPER_CACHE_HOST_DIR=faster-whisper-cache
FASTER_WHISPER_MODEL=Systran/faster-whisper-small
FASTER_WHISPER_DEVICE=cpu
# FASTER_WHISPER_DEVICE=cuda
FASTER_WHISPER_DEVICE_INDEX=0
FASTER_WHISPER_COMPUTE_TYPE=int8
# FASTER_WHISPER_COMPUTE_TYPE=float16
FASTER_WHISPER_CPU_THREADS=0
FASTER_WHISPER_NUM_WORKERS=1
FASTER_WHISPER_TTL_SECONDS=300
FASTER_WHISPER_PRELOAD_MODELS=[]
FASTER_WHISPER_ENABLE_UI=false

# Linux RAM-backed shared storage. The *_HOST_DIR values are bind-mount sources
# on the Linux host. The non-HOST values are the in-container paths used by the
# Python runtime.
LOOKBACK_BUFFER_HOST_DIR=/dev/shm/clutchcam
LOOKBACK_BUFFER_DIR=/dev/shm/clutchcam
AUDIO_EXTRACT_HOST_DIR=/dev/shm/clutchcam-audio
AUDIO_EXTRACT_DIR=/dev/shm/clutchcam-audio

LOOKBACK_WINDOW_SECONDS=30
SWITCH_LOOKBACK_SECONDS=15
LOOKBACK_SEGMENT_SECONDS=2
FFMPEG_EXECUTABLE=ffmpeg

# Optional per-stream buffer input overrides. If omitted, each stream defaults
# to <INGEST_API_URL>/<stream_id>.
LOOKBACK_INPUT_URL_PLAYER_1=rtmp://media-server:1935/live/player_1
LOOKBACK_INPUT_URL_PLAYER_2=rtmp://media-server:1935/live/player_2
LOOKBACK_INPUT_URL_PLAYER_3=rtmp://media-server:1935/live/player_3
LOOKBACK_INPUT_URL_PLAYER_4=rtmp://media-server:1935/live/player_4

# Audio extraction settings for orchestrator live transcription or the
# standalone transcription-worker diagnostic path.
AUDIO_EXTRACT_SAMPLE_RATE=16000
AUDIO_EXTRACT_CHANNELS=1
AUDIO_EXTRACT_CHUNK_SECONDS=5
AUDIO_EXTRACT_CODEC=pcm_s16le
AUDIO_EXTRACT_CONTAINER=wav

# Optional per-stream audio input overrides. If omitted, audio extraction
# falls back to LOOKBACK_INPUT_URL_* and then <INGEST_API_URL>/<stream_id>.
AUDIO_INPUT_URL_PLAYER_1=rtmp://media-server:1935/live/player_1
AUDIO_INPUT_URL_PLAYER_2=rtmp://media-server:1935/live/player_2
AUDIO_INPUT_URL_PLAYER_3=rtmp://media-server:1935/live/player_3
AUDIO_INPUT_URL_PLAYER_4=rtmp://media-server:1935/live/player_4

# Director behavior.
CONFIDENCE_THRESHOLD=0.75
MIN_SWITCH_INTERVAL_SECONDS=8
MAX_FOCUS_DURATION_SECONDS=20
TRANSCRIPT_HISTORY_SECONDS=30
TRANSCRIPT_HISTORY_MESSAGES=20
TRANSCRIPT_UTTERANCE_MAX_GAP_SECONDS=2.0
TRANSCRIPT_UTTERANCE_MAX_DURATION_SECONDS=8.0
TRANSCRIPT_UTTERANCE_MAX_CHARACTERS=240
TRANSCRIPT_UTTERANCE_MAX_EVENTS=8
TRANSCRIPT_PREFILTER_ENABLED=true
TRANSCRIPT_PREFILTER_MIN_TEXT_CHARACTERS=6
TRANSCRIPT_PREFILTER_DUPLICATE_WINDOW_SECONDS=12
TRANSCRIPT_PREFILTER_CONTEXT_SECONDS=30
TRANSCRIPT_PREFILTER_MIN_CONFIDENCE=0.70
