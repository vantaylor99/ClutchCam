# OBS WebSocket settings.
# In OBS: Tools > WebSocket Server Settings.
OBS_HOST=host.docker.internal
OBS_PORT=4455
OBS_PASSWORD=change-me
DRY_RUN_OBS=false

# Production service boundaries.
INGEST_API_URL=rtmp://media-server:1935/live
TRANSCRIPTION_API_URL=http://faster-whisper:8000
LOOKBACK_BUFFER_DIR=/dev/shm/clutchcam
LOOKBACK_WINDOW_SECONDS=30
SWITCH_LOOKBACK_SECONDS=15

# Local SRS media-server settings.
# Keep SRS_BIND_ADDR=127.0.0.1 for host-local testing. Use 0.0.0.0 only when
# the LAN firewall boundary is intentional.
SRS_IMAGE=ossrs/srs:6
SRS_BIND_ADDR=127.0.0.1
SRS_RTMP_PORT=1935
SRS_HTTP_API_PORT=1985
SRS_HTTP_STREAM_PORT=8080
SRS_SRT_PORT=10080

# Gemma/Ollama settings.
# GEMMA_* names are preferred. OLLAMA_* aliases still work for the current MVP.
GEMMA_MODEL=gemma3:4b
GEMMA_API_URL=http://ollama:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_BASE_URL=http://ollama:11434

# Director behavior.
CONFIDENCE_THRESHOLD=0.75
MIN_SWITCH_INTERVAL_SECONDS=8
MAX_FOCUS_DURATION_SECONDS=20
TRANSCRIPT_HISTORY_SECONDS=30
TRANSCRIPT_HISTORY_MESSAGES=20
