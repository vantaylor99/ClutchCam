# Compose profiles.
# Use local-ai for the bundled Ollama service, or omit it when GEMMA_API_URL
# points at a host or remote GPU endpoint.
COMPOSE_PROFILES=media-server,buffer-worker,transcription-worker,orchestrator,local-ai

# OBS WebSocket settings.
# In OBS: Tools > WebSocket Server Settings.
OBS_HOST=host.docker.internal
OBS_PORT=4455
OBS_PASSWORD=change-me
DRY_RUN_OBS=false

# Local SRS media-server settings.
# Keep SRS_BIND_ADDR=127.0.0.1 for host-local testing. Use 0.0.0.0 only when
# the LAN firewall boundary is intentional.
SRS_IMAGE=ossrs/srs:6
SRS_BIND_ADDR=127.0.0.1
SRS_RTMP_PORT=1935
SRS_HTTP_API_PORT=1985
SRS_HTTP_STREAM_PORT=8080
SRS_SRT_PORT=10080

# Runtime service boundaries.
# Compose workers default to the local media-server DNS name. Override this
# when media ingest is supplied by another host.
INGEST_API_URL=rtmp://media-server:1935/live

# GEMMA_API_URL and TRANSCRIPTION_API_URL are endpoint contracts. They may use
# Compose service DNS, host.docker.internal, or remote HTTP(S) endpoints.
AI_PROVIDER=ollama
# AI_PROVIDER=openai-compatible
GEMMA_API_URL=http://ollama:11434
# GEMMA_API_URL=http://host.docker.internal:11434
# For OpenAI-compatible servers such as vLLM, point at the host or a full
# /v1/chat/completions path.
# GEMMA_API_URL=https://gemma-gpu.example.internal
GEMMA_API_KEY=
TRANSCRIPTION_API_URL=http://host.docker.internal:8000
# TRANSCRIPTION_API_URL=https://stt-gpu.example.internal
TRANSCRIPTION_REQUEST_TIMEOUT_SECONDS=30

# Local AI model storage.
OLLAMA_BIND_ADDR=127.0.0.1
OLLAMA_PORT=11434
GEMMA_MODEL=gemma3:4b
OLLAMA_MODEL=gemma3:4b
OLLAMA_BASE_URL=http://ollama:11434

# Linux RAM-backed shared storage. The *_HOST_DIR values are bind-mount sources
# on the Linux host. The non-HOST values are the in-container paths used by the
# Python runtime.
LOOKBACK_BUFFER_HOST_DIR=/dev/shm/clutchcam
LOOKBACK_BUFFER_DIR=/dev/shm/clutchcam
AUDIO_EXTRACT_HOST_DIR=/dev/shm/clutchcam-audio
AUDIO_EXTRACT_DIR=/dev/shm/clutchcam-audio

LOOKBACK_WINDOW_SECONDS=30
SWITCH_LOOKBACK_SECONDS=15
LOOKBACK_SEGMENT_SECONDS=2
FFMPEG_EXECUTABLE=ffmpeg

# Optional per-stream buffer input overrides. If omitted, each stream defaults
# to <INGEST_API_URL>/<stream_id>.
LOOKBACK_INPUT_URL_PLAYER_1=rtmp://media-server:1935/live/player_1
LOOKBACK_INPUT_URL_PLAYER_2=rtmp://media-server:1935/live/player_2
LOOKBACK_INPUT_URL_PLAYER_3=rtmp://media-server:1935/live/player_3
LOOKBACK_INPUT_URL_PLAYER_4=rtmp://media-server:1935/live/player_4

# Audio extraction settings for the transcription worker.
AUDIO_EXTRACT_SAMPLE_RATE=16000
AUDIO_EXTRACT_CHANNELS=1
AUDIO_EXTRACT_CHUNK_SECONDS=5
AUDIO_EXTRACT_CODEC=pcm_s16le
AUDIO_EXTRACT_CONTAINER=wav

# Optional per-stream audio input overrides. If omitted, audio extraction
# falls back to LOOKBACK_INPUT_URL_* and then <INGEST_API_URL>/<stream_id>.
AUDIO_INPUT_URL_PLAYER_1=rtmp://media-server:1935/live/player_1
AUDIO_INPUT_URL_PLAYER_2=rtmp://media-server:1935/live/player_2
AUDIO_INPUT_URL_PLAYER_3=rtmp://media-server:1935/live/player_3
AUDIO_INPUT_URL_PLAYER_4=rtmp://media-server:1935/live/player_4

# Director behavior.
CONFIDENCE_THRESHOLD=0.75
MIN_SWITCH_INTERVAL_SECONDS=8
MAX_FOCUS_DURATION_SECONDS=20
TRANSCRIPT_HISTORY_SECONDS=30
TRANSCRIPT_HISTORY_MESSAGES=20
TRANSCRIPT_PREFILTER_ENABLED=true
TRANSCRIPT_PREFILTER_MIN_TEXT_CHARACTERS=6
TRANSCRIPT_PREFILTER_DUPLICATE_WINDOW_SECONDS=12
TRANSCRIPT_PREFILTER_CONTEXT_SECONDS=30
TRANSCRIPT_PREFILTER_MIN_CONFIDENCE=0.70
